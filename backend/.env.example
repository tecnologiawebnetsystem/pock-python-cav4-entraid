# =============================================================================
# POC — Login no CA Petrobras (Entra) + consulta CAv4
# -----------------------------------------------------------------------------
# Como usar:
#   1) Copie este arquivo:   cp .env.example .env
#   2) Confirme a OIDC_DISCOVERY_URL com o time do CA (pode ter um realm).
#   3) Suba o backend e acesse /auth/login no navegador.
#
# Os valores abaixo são do ambiente DSV (desenvolvimento). NÃO use em HOM/PROD.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. IDENTIDADE DA APLICAÇÃO NO CA (do registro da aplicação — DSV)
# -----------------------------------------------------------------------------

# clientId público da aplicação registrada no CA. (DSV — Apl A12022 / Regional RIO)
CA_CLIENT_ID=f1f4d0d4-d39f-4cdc-b6a3-5f39c95ea3a0

# clientSecret da aplicação. É um SEGREDO. Em DSV pode ficar aqui, mas em
# HOM/PROD deve vir do Secrets Manager / variável de ambiente, nunca versionado.
CA_CLIENT_SECRET=a7b3b0a163bc4539a1ff6afa54db067a

# redirectUri: para onde o CA devolve o usuário APÓS o login, com o "code"
# que o backend troca pelos dados do Entra/CAv4. É EXIGIDO pelo protocolo OIDC
# (sem ele o login não acontece) e precisa ser EXATAMENTE igual ao registrado no CA.
#
# Como agora é SÓ backend (sem redirecionar para o site scac-dsv), aponte para
# o PRÓPRIO backend local — assim o usuário volta para a sua máquina e o
# resultado aparece no terminal. Para isso funcionar, este endereço também
# precisa estar cadastrado no registro da aplicação no CA.
CA_REDIRECT_URI=http://localhost:8000/auth/entra-callback

# Scopes do OIDC solicitados no login. A app registrou "openid" e "profile".
# O acesso ao Microsoft Graph agora e INDEPENDENTE (secao 3b), entao aqui NAO
# precisa de User.Read.
CA_SCOPES=openid profile

# -----------------------------------------------------------------------------
# 2. ENDPOINTS OIDC — servidor de AUTENTICAÇÃO (OAuth) do CAv4
# -----------------------------------------------------------------------------

# URL do documento de descoberta OIDC (termina em /.well-known/openid-configuration).
#   RIC (rede interna): https://caauthz.petrobras.com.br
#   DMZ (externa):      https://authz.petrobras.com.br
# Como a app é interna (scac-dsv), usamos o host RIC.
OIDC_DISCOVERY_URL=https://caauthz.petrobras.com.br/.well-known/openid-configuration

# Alternativa: informe os endpoints manualmente (só usados se DISCOVERY_URL vazio).
OIDC_ISSUER=
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_JWKS_URI=

# Valida a assinatura do id_token via JWKS. Mantenha "true" sempre que possível.
OIDC_VERIFY_SIGNATURE=true

# -----------------------------------------------------------------------------
# 3. USER API DO CAv4 (autorização: recursos, grupos, alocação...)
# -----------------------------------------------------------------------------

# Host base da API REST do CA (sem barra no final).
#   RIC (rede interna): https://fwca.petrobras.com.br
#   DMZ (externa):      https://fwca-apps.petrobras.com.br
CA_API_BASE_URL=https://fwca.petrobras.com.br

# -----------------------------------------------------------------------------
# 3b. MICROSOFT GRAPH — ACESSO INDEPENDENTE DO CAv4 (app-only / app proprio)
# -----------------------------------------------------------------------------
# Estas credenciais sao de uma app registration PROPRIA no Entra ID, separada
# do CAv4. O backend obtem seu PROPRIO token (client credentials) e consulta o
# Graph diretamente — sem reutilizar o token do login/CAv4.
#
# Pre-requisitos no Entra (portal):
#   1) Registrar uma aplicacao -> copie o "Directory (tenant) ID" e o
#      "Application (client) ID".
#   2) Em "Certificates & secrets", crie um client secret -> copie o VALOR.
#   3) Em "API permissions", adicione Microsoft Graph -> tipo APLICACAO:
#      User.Read.All -> e clique em "Grant admin consent".
#
# Sem estas 3 variaveis, as consultas ao Graph (#6 e #7) retornam erro
# controlado (GRAPH_NOT_CONFIGURED), sem afetar as consultas do CAv4.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# Host base do Microsoft Graph (sem barra no final). Padrao ja serve.
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
# Authority do Entra para obter o token de aplicacao. Padrao ja serve.
GRAPH_AUTHORITY=https://login.microsoftonline.com
# Scope do client credentials. Sempre o .default da app no Graph.
GRAPH_SCOPE=https://graph.microsoft.com/.default

# -----------------------------------------------------------------------------
# 4. TLS / certificados (rede corporativa Petrobras)
# -----------------------------------------------------------------------------
# Os hosts caauthz/fwca usam certificados de uma CA INTERNA da Petrobras. O
# navegador confia (Windows), mas o Python (httpx/certifi) NÃO — o que pode
# causar erro de SSL no login (CERTIFICATE_VERIFY_FAILED / 500).
#
# Solução recomendada (PADRÃO): truststore. O backend usa o repositório de
# certificados do SISTEMA (Windows/macOS), confiando nas MESMAS CAs internas
# que o navegador e o PowerShell já confiam. Não precisa exportar .pem.
# Deixe "true" (padrão). Só mude para "false" se quiser forçar o uso do certifi.
CA_SSL_USE_TRUSTSTORE=true
#
# Alternativa: aponte para um bundle .pem com a CA raiz interna da Petrobras.
#   Windows: CA_SSL_CERT_FILE=C:\certs\petrobras-ca.pem
#   Linux:   CA_SSL_CERT_FILE=/etc/ssl/certs/petrobras-ca.pem
CA_SSL_CERT_FILE=
#
# Opção rápida só para DSV (INSEGURA — nunca em HOM/PROD): desliga a verificação.
#   CA_SSL_VERIFY=false
CA_SSL_VERIFY=true

# -----------------------------------------------------------------------------
# 5. CORS
# -----------------------------------------------------------------------------
# Origens permitidas (separadas por vírgula). Opcional: como o projeto é só
# backend, deixe vazio (o padrão será "*"). Use apenas se um cliente web externo
# for consumir a API diretamente do navegador.
CORS_ALLOW_ORIGINS=
